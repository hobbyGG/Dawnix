{
  "inputs": [
    {
      "type": "promptString",
      "id": "pg_url",
      "description": "PostgreSQL URL (project default example: postgresql://root:123@localhost:5432/root?sslmode=disable)"
    },
    {
      "type": "promptString",
      "id": "redis_url",
      "description": "Redis URL (project default example: redis://127.0.0.1:16379)"
    }
  ],
  "servers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${input:pg_url}"
      ]
    },
    "redis": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis"
      ],
      "env": {
        "REDIS_URL": "${input:redis_url}"
      }
    }
  }
}
